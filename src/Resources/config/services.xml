<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="Swag\AiAssistant\Service\OllamaClient">
            <argument type="service" id="http_client"/>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
        </service>

        <service id="Swag\AiAssistant\Service\KiService">
            <argument type="service" id="Swag\AiAssistant\Service\OllamaClient"/>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
        </service>

        <service id="Swag\AiAssistant\Service\EntityResolver">
            <argument type="service" id="product_manufacturer.repository"/>
            <argument type="service" id="tax.repository"/>
            <argument type="service" id="category.repository"/>
            <argument type="service" id="property_group.repository"/>
            <argument type="service" id="property_group_option.repository"/>
        </service>

        <service id="Swag\AiAssistant\Service\DraftManager">
            <argument type="service" id="product.repository"/>
        </service>

        <service id="Swag\AiAssistant\Service\ProductCreator">
            <argument type="service" id="product.repository"/>
            <argument type="service" id="currency.repository"/>
            <argument type="service" id="sales_channel.repository"/>
            <argument type="service" id="Swag\AiAssistant\Service\DraftManager"/>
            <argument type="service" id="Swag\AiAssistant\Service\EntityResolver"/>
        </service>

        <service id="Swag\AiAssistant\Service\ProductImportService">
            <argument type="service" id="Swag\AiAssistant\Service\KiService"/>
            <argument type="service" id="Swag\AiAssistant\Service\ProductCreator"/>
            <argument type="service" id="Swag\AiAssistant\Service\DraftManager"/>
            <argument type="service" id="Swag\AiAssistant\Service\EntityResolver"/>
        </service>

        <service id="Swag\AiAssistant\Command\AiProductImportCommand">
            <argument type="service" id="Swag\AiAssistant\Service\ProductImportService"/>
            <argument type="service" id="Swag\AiAssistant\Service\DraftManager"/>
            <tag name="console.command"/>
        </service>

        <service id="Swag\AiAssistant\Message\ImportProductHandler">
            <argument type="service" id="Swag\AiAssistant\Service\ProductImportService"/>
            <tag name="messenger.message_handler"/>
        </service>

        <service id="Swag\AiAssistant\Controller\AiImportController" public="true">
            <argument type="service" id="Swag\AiAssistant\Service\ProductImportService"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>
    </services>
</container>
